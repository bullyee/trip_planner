rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // Users can only access their own backup blobs
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}