rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny for all paths not explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 1. Cloud Sync Backup Metadata (Private to user)
    // ==========================================
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // 2. Helpers
    // ==========================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // The trip must EXIST and the caller must be its author or a listed member.
    // (Removed the old "tripDoc == null -> true" short-circuit, which let any
    // authenticated user write under a non-existent trip id.)
    function isTripMember(roiId) {
      let tripDoc = get(/databases/$(database)/documents/trips/$(roiId));
      return tripDoc != null && (
        request.auth.uid == tripDoc.data.authorId ||
        (('members' in tripDoc.data) && request.auth.uid in tripDoc.data.members)
      );
    }

    function isStrictTimeChunkSafe() {
      let data = request.resource.data;
      let allowedKeys = [
        'id', 'poiId', 'date', 'startTime', 'endTime',
        'status', 'sortOrder', 'duration', 'transitDuration',
        'isFixedTime', 'authorId', 'updatedAt'
      ];
      let hasOnlyAllowedKeys = data.keys().hasOnly(allowedKeys);

      let isStatusSafe = !('status' in data) || data.status == null || (data.status is string && data.status.size() <= 30);
      let isIdSafe = !('id' in data) || (data.id is string && data.id.size() <= 100);
      let isDurationSafe = !('duration' in data) || (data.duration is number && data.duration >= 0);

      return hasOnlyAllowedKeys && isStatusSafe && isIdSafe && isDurationSafe;
    }

    function isStrictPoiSafe() {
      let data = request.resource.data;
      let allowedKeys = [
        'id', 'roiId', 'authorId', 'name', 'description', 'address',
        'lat', 'lng', 'businessHours', 'contactInfo',
        'remoteCoverImageUrl', 'sortOrder', 'updatedAt'
      ];
      return data.keys().hasOnly(allowedKeys)
        && (!('id' in data) || (data.id is string && data.id.size() <= 100))
        && (!('name' in data) || (data.name is string && data.name.size() <= 300));
    }

    // ==========================================
    // 3. Dual-Track: Shared Trips (Collaborative)
    // ==========================================
    match /trips/{tripId} {
      // Creator must be the author and list themselves as a member.
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && (request.auth.uid in request.resource.data.members);

      // Allow reading a non-existent trip doc (resource == null) so the client
      // can check existence (tripExists) and the self-heal can recreate a
      // deleted trip. Existing trips stay gated to members.
      allow read: if isAuthenticated() && (resource == null || isTripMember(tripId));
      allow delete: if isAuthenticated() && isTripMember(tripId);

      allow update: if isAuthenticated() && isTripMember(tripId) && (
        // (a) Lock-only change: acquire/release the sync lock.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['syncLock']))
        ||
        // (b) A real sync commit: monotonic version bump, lock respected, and
        //     membership / authorship are NOT allowed to change here.
        (
          request.resource.data.cloudVersion == resource.data.cloudVersion + 1
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.members == resource.data.members
          && (!('syncLock' in request.resource.data) || request.resource.data.syncLock == null)
          && (
            resource.data.syncLock == null
            || request.time > resource.data.syncLock.expiresAt
            || resource.data.syncLock.userId == request.auth.uid
          )
        )
      );

      match /timeChunks/{chunkId} {
        allow read: if isAuthenticated() && isTripMember(tripId);
        allow write: if isAuthenticated() && isTripMember(tripId) && isStrictTimeChunkSafe();
      }

      match /pois/{poiId} {
        allow read: if isAuthenticated() && isTripMember(tripId);
        allow write: if isAuthenticated() && isTripMember(tripId) && isStrictPoiSafe();
      }
    }
  }
}
