rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny for all paths not explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 1. Cloud Sync Backup Metadata (Private to user)
    // ==========================================
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // 2. Dual-Track: Shared Trips (Collaborative)
    // ==========================================
    match /trips/{tripId} {
      // Create: user must include themselves in the 'members' array
      allow create: if request.auth != null && (request.auth.uid in request.resource.data.members);
      // Read/Update/Delete: user must be in the existing 'members' array
      allow read, update, delete: if request.auth != null && (request.auth.uid in resource.data.members);

      // Sub-collections inherit permissions via get()
      match /{document=**} {
        allow read, write: if request.auth != null && 
          (request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members);
      }
    }
  }
}